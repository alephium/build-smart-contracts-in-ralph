Contract Loop() {
    pub fn whileStmt() -> U256 {
        let mut index = 0
        let mut sum = 0
        while (index <= 4) {
          sum += index
          index += 1
        }
        return sum
    }

    pub fn forStmt() -> U256 {
        let array = [1, 2, 3, 4, 5]
        let mut sum = 0
        for (let mut i = 0; i <= 5; i += 1) {
            sum += array[i]
        }
        return sum
    }
}