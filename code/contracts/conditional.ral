Contract Conditional() {
    pub fn ifExpr(a: U256) -> ByteVec {
       return if (a == 0) #00 else if (a == 1) #01 else #02
    }

    pub fn ifStmt(a: U256) -> ByteVec {
        if (a == 0) {
            return #00
        } else if (a == 1) {
            return #01
        } else {
            return #02
        }
    }
}